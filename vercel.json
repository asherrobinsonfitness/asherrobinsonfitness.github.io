{
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/edge/fbevents.js", "destination": "https://connect.facebook.net/en_US/fbevents.js" },
    { "source": "/edge/tr", "destination": "https://www.facebook.com/tr" }
  ]
}
